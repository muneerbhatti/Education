<%#
# Application Layout

This view template is used as the layout
for every page that Administrate generates.

By default, it renders:
- Navigation
- Content for a search bar
  (if provided by a `content_for` block in a nested page)
- Flashes
- Links to stylesheets and JavaScripts
%>

<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <meta name="ROBOTS" content="NOODP">
  <meta name="viewport" content="initial-scale=1">
  <title>
    <%= content_for(:title) %> - <%= application_title %>
  </title>
  <%= render "stylesheet" %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag if defined?(csp_meta_tag) %>
  <%= render "javascript" %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/7.3.0/tinymce.min.js"></script>

</head>
<body>
  <%= render "icons" %>

  <div class="app-container">
    <%= render "navigation" -%>

    <main class="main-content">
      <%= render "flashes" -%>
      <%= yield %>
    </main>
  </div>
  <!-- TinyMCE Init — placed at bottom of body -->
  <script>
    function initTinyMCE() {
      if (typeof tinymce !== "undefined") {
        tinymce.remove(".tinymce-editor");
        tinymce.init({
          selector: ".tinymce-editor",
          plugins: "lists link image code table",
          toolbar: "undo redo | bold italic | underline | alignleft aligncenter alignright | bullist numlist | link image | code",
          height: 400,
          menubar: false,
          promotion: false,
          branding: false,
          // 👇 These 3 lines are all you need for Base64
          //images_upload_handler: function (blobInfo) {
          //  return Promise.resolve("data:" + blobInfo.blob().type + ";base64," + blobInfo.base64());
          //},
          statusbar: false,
          relative_urls : false,
          remove_script_host : false,
          convert_urls: true,
          document_base_url: 'http://localhost:3000/',
          images_upload_handler: function (blobInfo, success, failure) {
            let formData = new FormData();
            formData.append("file", blobInfo.blob(), blobInfo.filename());

            return fetch("/tinymce_upload", {
              method: "POST",
              body: formData,
              headers: {
                "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
              }
            })
              .then(res => res.json())
              .then(data => {
                return data.location;
              })
              .catch(err => {
                console.error(err);
                failure("Upload failed");
              });
          },
          automatic_uploads: true,
          paste_data_images: true,
          images_reuse_filename: true,
          valid_elements: "*[*]",
          extended_valid_elements: "img[src|alt|width|height|style]",

        });
      }
    }

    document.addEventListener("turbo:load", initTinyMCE);
    document.addEventListener("DOMContentLoaded", initTinyMCE);

    document.addEventListener("turbo:before-cache", function () {
      if (typeof tinymce !== "undefined") {
        tinymce.remove(".tinymce-editor");
      }
    });
  </script>
</body>
</html>
