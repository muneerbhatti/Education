<!-- Page Title Banner Start -->
<section class="page_title_banner">
    <div class="container">
        <div class="content">
            <div class="title">
                <h1>Subscription Successful</h1>
                <p>We’ve saved your subscription and will send our next newsletter soon. Stay tuned for course updates, blog posts, and special events.</p>
                <img src="<%=asset_path 'tag-2.png'%>" alt="" class="tag">
            </div>
            <div class="educate-tilt"
                data-tilt-options='{ "glare": false, "maxGlare": 0, "maxTilt": 2, "speed": 700, "scale": 1 }'>
                <img src="<%=asset_path 'page_title.png'%>" alt="" class="main_img">
            </div>
            <img src="<%=asset_path 'circle-lines-2.png'%>" alt="" class="circle_vector">
        </div>
        <a href="<%=courses_path%>" class="educate-btn"><span class="educate-btn__curve"></span>Browse Courses</a>
    </div>
</section>
<!-- Page Title Banner End -->


<!-- Discount Banner Area Start -->
<section class="discount_banner">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-xl-6 col-lg-5">
                <div class="banner_text_block">
                    <div class="title_block mb-16">
                        <h2 class="title">Start Your
                            <span class="fm-sec">ABA Journey Today!
                                <img src="<%=asset_path 'line-vector.png'%>" alt="" class="line_shape">
                                <img src="<%=asset_path 'mic-speaker.png'%>" alt="" class="mic_speaker">
                            </span>
                        </h2>
                    </div>
                    <h4 class="mb-12">Free Consultation Available! </h4>
                    <p class="mb-24">Together, we can create meaningful change and empower every individual to reach their fullest potential through evidence-based ABA therapy and specialized support services.</p>
                    <a href="<%=contact_us_path%>" class="educate-btn"><span class="educate-btn__curve"></span>Contact Us</a>
                </div>
            </div>
            <div class="col-xl-6 col-lg-7">
                <div class="discount_countdown">
                    <div class="dial">
                        <ul class="top-remain">
                            <li class=" remain-count">02</li>
                            <li class=" remain-count">01</li>
                            <li class=" remain-count">00</li>
                        </ul>
                        <ul class="top-coming">
                            <li>02</li>
                            <li>01</li>
                            <li>00</li>
                        </ul>
                    </div>
                    <img src="<%=asset_path 'paint-shape.png'%>" alt="" class="paint_shape">
                    <ul class="countdown unstyled">
                        <li>
                            <h2>365</h2>
                            <h6>Days</h6>
                        </li>
                        <li>
                            <h2>24</h2>
                            <h6>Hrs</h6>
                        </li>
                        <li>
                            <h2>60</h2>
                            <h6>Min</h6>
                        </li>
                        <li>
                            <h2><span>60</span></h2>
                            <h6>Sec</h6>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Discount Banner Area End -->




